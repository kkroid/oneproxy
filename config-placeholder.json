{
  "version": "1.0",
  "log_level": "info",
  "unified": {
    "port": 1080
  },
  "route_mode": "rule",
  "health_check": {
    "enabled": true,
    "interval_seconds": 60,
    "timeout_seconds": 5,
    "test_url": "https://www.google.com/generate_204"
  },
  "dns": {
    "flush_on_failure": true,
    "flush_interval_seconds": 300,
    "servers": ["https://1.1.1.1/dns-query", "https://8.8.8.8/dns-query"]
  },
  "proxies": [
    {
      "name": "Example-Server",
      "enabled": true,
      "local_port": 10801,
      "type": "shadowsocks",
      "server": "your-server.example.com",
      "port": 8388,
      "method": "aes-256-gcm",
      "password": "your-password-here"
    }
  ],
  "inbound": {
    "listen": "127.0.0.1"
  }
}
