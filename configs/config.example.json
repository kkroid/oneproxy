{
  "version": "1.0",
  "log_level": "info",

  "health_check": {
    "enabled": true,
    "interval_seconds": 60,
    "timeout_seconds": 5,
    "test_url": "https://www.google.com/generate_204"
  },

  "dns": {
    "flush_on_failure": true,
    "flush_interval_seconds": 300,
    "servers": ["https://1.1.1.1/dns-query", "https://8.8.8.8/dns-query"]
  },

  "proxies": [
    {
      "name": "Proxy-1",
      "enabled": true,
      "local_port": 10801,
      "type": "shadowsocks",
      "server": "example1.yourproxy.com",
      "port": 8388,
      "method": "aes-256-gcm",
      "password": "your-password-here"
    },
    {
      "name": "Proxy-2",
      "enabled": true,
      "local_port": 10802,
      "type": "shadowsocks",
      "server": "example2.yourproxy.com",
      "port": 8388,
      "method": "aes-256-gcm",
      "password": "your-password-here"
    },
    {
      "name": "Proxy-3",
      "enabled": true,
      "local_port": 10803,
      "type": "vmess",
      "server": "example3.yourproxy.com",
      "port": 443,
      "uuid": "your-uuid-here",
      "alter_id": 0,
      "security": "auto"
    }
  ],

  "inbound": {
    "listen": "127.0.0.1",
    "proxy_type": "socks5"
  }
}
