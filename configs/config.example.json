{
  "version": "1.0",
  "log_level": "info",
  "health_check": {
    "enabled": true,
    "interval_seconds": 60,
    "timeout_seconds": 5,
    "test_url": "https://www.google.com/generate_204"
  },
  "dns": {
    "flush_on_failure": true,
    "flush_interval_seconds": 300,
    "servers": ["https://1.1.1.1/dns-query", "https://8.8.8.8/dns-query"]
  },
  "proxies": [
    {
      "name": "JMS-Server1",
      "enabled": true,
      "local_port": 10801,
      "type": "shadowsocks",
      "server": "c331s1.portablesubmari",
      "port": 5299,
      "method": "aes-256-gcm",
      "password": "your-password-here"
    },
    {
      "name": "JMS-Server2",
      "enabled": true,
      "local_port": 10802,
      "type": "shadowsocks",
      "server": "c331s2.portablesubmari",
      "port": 5299,
      "method": "aes-256-gcm",
      "password": "your-password-here"
    },
    {
      "name": "JMS-Server3",
      "enabled": true,
      "local_port": 10803,
      "type": "vmess",
      "server": "c331s3.portablesubmari",
      "port": 5299,
      "uuid": "your-uuid-here",
      "alter_id": 0,
      "security": "auto"
    },
    {
      "name": "JMS-Server4",
      "enabled": true,
      "local_port": 10804,
      "type": "vmess",
      "server": "c331s4.portablesubmari",
      "port": 5299,
      "uuid": "your-uuid-here",
      "alter_id": 0,
      "security": "auto"
    },
    {
      "name": "JMS-Server5",
      "enabled": true,
      "local_port": 10805,
      "type": "shadowsocks",
      "server": "c331s5.portablesubmari",
      "port": 5299,
      "method": "aes-256-gcm",
      "password": "your-password-here"
    }
  ],
  "inbound": {
    "listen": "127.0.0.1",
    "proxy_type": "socks5"
  }
}
